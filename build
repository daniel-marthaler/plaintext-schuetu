
#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# ── Load shared libraries ────────────────────────────────────
SCRIPTS_DIR="$HOME/.plaintext-scripts"
if [ ! -f "$SCRIPTS_DIR/tui-common.sh" ]; then
    echo "plaintext-scripts not found, cloning to $SCRIPTS_DIR..."
    git clone git@github.com:daniel-marthaler/plaintext-scripts.git "$SCRIPTS_DIR"
fi
source "$SCRIPTS_DIR/tui-common.sh"
source "$SCRIPTS_DIR/tui-build-logic.sh"

# ── Initialize versions ──────────────────────────────────────
init_versions

# ── Command execution (digit dispatch) ───────────────────────

execute_command() {
    local CMD="$1"

    case "$CMD" in
        0)
            exec "$0" run
            ;;
        1)
            exec "$0" build
            ;;
        2)
            exec "$0" release 1
            ;;
        3)
            exec "$0" release
            ;;
        4)
            exec "$0" release 3
            ;;
        5)
            exec "$0" release deploy-healthcheck
            ;;
        6)
            exec "$0" deploy-prod-healthcheck
            ;;
        7)
            do_release "deploy-healthcheck"
            deploy_to_prod "true" || exit 1
            ;;
        *)
            echo -e "${RED}Invalid option: ${CMD}${NC}"
            exit 1
            ;;
    esac
}

# ── Non-interactive mode (arguments provided) ────────────────

COMMAND=$1

if [ -n "$COMMAND" ]; then
    # Stop Twingate at the start if it would interfere with NAS operations
    case "$COMMAND" in
        0|run|help|-h|--help) ;; # no NAS access needed
        *)
            if is_twingate_running; then
                stop_twingate
            fi
            ;;
    esac

    # Ensure Twingate is restarted on exit (if we stopped it)
    trap 'restart_twingate_if_needed' EXIT

    # Check if command is a sequence of digits (multi-command execution)
    if [[ "$COMMAND" =~ ^[0-9]+$ ]] && [ ${#COMMAND} -gt 1 ]; then
        echo -e "${BLUE}=== Executing command sequence: ${COMMAND} ===${NC}"

        for (( i=0; i<${#COMMAND}; i++ )); do
            DIGIT="${COMMAND:$i:1}"
            echo -e "${YELLOW}=== Step $((i+1))/${#COMMAND}: Executing command ${DIGIT} ===${NC}"

            "$0" "$DIGIT"
            EXIT_CODE=$?

            if [ $EXIT_CODE -ne 0 ]; then
                echo -e "${RED}=== Command ${DIGIT} failed with exit code ${EXIT_CODE} ===${NC}"
                echo -e "${RED}=== Stopping command sequence ===${NC}"
                exit $EXIT_CODE
            fi

            echo -e "${GREEN}=== Command ${DIGIT} completed successfully ===${NC}"
            echo ""
        done

        echo -e "${GREEN}=== All commands completed successfully! ===${NC}"
        exit 0
    fi

    case "$COMMAND" in
        0)
            exec "$0" run
            ;;

        1)
            exec "$0" build
            ;;

        2)
            exec "$0" release 1
            ;;

        3)
            exec "$0" release
            ;;

        4)
            exec "$0" release 3
            ;;

        5)
            exec "$0" release deploy-healthcheck
            ;;

        6)
            exec "$0" deploy-prod-healthcheck
            ;;

        7)
            do_release "deploy-healthcheck"
            deploy_to_prod "true" || exit 1
            ;;

        help|-h|--help)
            show_usage
            exit 0
            ;;

        run)
            do_run || exit 1
            ;;

        build)
            do_build_snapshot "$2" || exit 1
            ;;

        release)
            do_release "$2" "$3" || exit 1
            ;;

        deploy-prod)
            deploy_to_prod || exit 1
            ;;

        deploy-prod-healthcheck)
            deploy_to_prod "true" || exit 1
            ;;

        setup-bluegreen)
            setup_blue_green || exit 1
            ;;

        *)
            echo -e "${RED}Unknown command: ${COMMAND}${NC}"
            echo ""
            show_usage
            exit 1
            ;;
    esac

    echo -e "${BLUE}Done!${NC}"
    exit 0
fi

# ── TUI (Interactive Mode) ───────────────────────────────────

# Menu items - parallel arrays for bash 3.2 compat
MENU_LABELS=()
MENU_LABELS+=("Build + Run (local)")
MENU_LABELS+=("Build (snapshot)")
MENU_LABELS+=("Release (major)")
MENU_LABELS+=("Release (minor)")
MENU_LABELS+=("Release (patch)")
MENU_LABELS+=("Release + Deploy DEV")
MENU_LABELS+=("Deploy Release to PROD")
MENU_LABELS+=("Release + Deploy DEV + PROD")
MENU_TOTAL=${#MENU_LABELS[@]}
MENU_MAX_IDX=$((MENU_TOTAL - 1))

CURSOR=0

tui_init
trap tui_cleanup EXIT

draw() {
    local total_height=$((1 + 3 + 2 + 1 + 1 + MENU_TOTAL + 1 + 1 + 1 + 1))

    tput clear
    tui_center $total_height

    # ── Top border ──
    tui_hline "┌" "─" "┐"

    # ── Blue band (3 lines: space, title, space) ──
    tui_nr; tui_band_row
    tui_nr; tui_band_title "${TUI_TITLE}"
    tui_nr; tui_band_row

    # ── Version info ──
    tui_nr; tui_row "  Version: ${CURRENT_VERSION}" "${FG_CYAN}"
    tui_nr; tui_row "  Release: ${RELEASE_VERSION:-n/a}" "${FG_CYAN}"

    # ── Separator ──
    tui_nr; tui_hline "├" "─" "┤"

    # ── Empty line before items ──
    tui_nr; tui_row "" ""

    # ── Menu items ──
    local i
    for ((i=0; i<MENU_TOTAL; i++)); do
        tui_nr
        if [[ $CURSOR -eq $i ]]; then
            tui_item_on "${MENU_LABELS[$i]}"
        else
            tui_item_off "${MENU_LABELS[$i]}"
        fi
    done

    # ── Empty line after items ──
    tui_nr; tui_row "" ""

    # ── Footer separator ──
    tui_nr; tui_hline "├" "─" "┤"

    # ── Footer help ──
    tui_nr; tui_row "  ↑↓ Navigate  ENTER Ausführen  H Help  Q Quit" "${FG_DIM}"

    # ── Bottom border ──
    tui_nr; tui_hline "└" "─" "┘"
}

show_help() {
    local total_height=18

    tput clear
    tui_center $total_height

    tui_hline "┌" "─" "┐"
    tui_nr; tui_row "" ""
    tui_nr; tui_row "  ${TUI_TITLE} - HELP" "${FG_WHITE}${BOLD}"
    tui_nr; tui_row "" ""
    tui_nr; tui_hline "├" "─" "┤"
    tui_nr; tui_row "  Tastatur:" "${FG_CYAN}${BOLD}"
    tui_nr; tui_row "    ↑ ↓       Navigieren" "${FG_CYAN}"
    tui_nr; tui_row "    ENTER     Auswahl ausfuehren" "${FG_CYAN}"
    tui_nr; tui_row "    0-7       Direkte Auswahl" "${FG_CYAN}"
    tui_nr; tui_row "    Q         Beenden" "${FG_CYAN}"
    tui_nr; tui_row "" ""
    tui_nr; tui_row "  CLI:" "${FG_CYAN}${BOLD}"
    tui_nr; tui_row "    ./build run       Bauen + Starten" "${FG_CYAN}"
    tui_nr; tui_row "    ./build 1         Snapshot Build" "${FG_CYAN}"
    tui_nr; tui_row "    ./build 56        Multi-Command" "${FG_CYAN}"
    tui_nr; tui_row "" ""
    tui_nr; tui_hline "├" "─" "┤"
    tui_nr; tui_row "  Beliebige Taste zum Schliessen..." "${FG_DIM}"
    tui_nr; tui_hline "└" "─" "┘"
    IFS= read -rsn1
}

# ── Main loop ─────────────────────────────────────────────────

draw

while true; do
    IFS= read -rsn1 key

    case "$key" in
        $'\x1b')
            # Escape sequence: read remaining chars
            read -rsn2 -t 1 seq || seq=""
            case "$seq" in
                '[A') # Up
                    [[ $CURSOR -gt 0 ]] && CURSOR=$((CURSOR - 1))
                    ;;
                '[B') # Down
                    [[ $CURSOR -lt $MENU_MAX_IDX ]] && CURSOR=$((CURSOR + 1))
                    ;;
            esac
            ;;
        '') # Enter key
            tui_cleanup
            echo ""
            execute_command "$CURSOR"
            exit 0
            ;;
        [0-7])
            # Number shortcut
            tui_cleanup
            echo ""
            execute_command "$key"
            exit 0
            ;;
        'q'|'Q')
            tui_cleanup
            echo ""
            exit 0
            ;;
        'h'|'H'|'?')
            show_help
            ;;
    esac

    draw
done
